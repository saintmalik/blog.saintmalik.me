# Cloudflare Pages cache headers
# Default: HTML and routes revalidate on every deploy (prevents stale HTML → missing CSS)
/*
  Cache-Control: public, max-age=0, must-revalidate

# Hashed webpack assets — safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Self-hosted fonts and font CSS — stable paths, long cache
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/img/*
  Cache-Control: public, max-age=31536000, immutable

/bgimg/*
  Cache-Control: public, max-age=31536000, immutable

# Prevent caching issues for service worker and manifest
/manifest.json
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate
